# Copy to .env and fill in values before running docker compose

# Your Mapbox public token (pk.eyJ1…) — baked into the frontend bundle at build time
VITE_MAPBOX_TOKEN=pk.your_token_here

# URL the browser uses to reach the API.
# Default (http://localhost:8000) works when both containers run on the same machine.
VITE_API_BASE_URL=http://localhost:8000
